  "grammarTopics": [
    {
      "id": "g5_26",
      "unit": 5,
      "code": "G26",
      "title": "Mengenangaben mit \"of\"",
      "explanation": "Um Mengen von zählbaren oder unzählbaren Dingen anzugeben, benutzt man Ausdrücke mit \"of\": a bottle of, a packet of, a piece of usw. Struktur: Mengenausdruck + of + Nomen.",
      "examples": ["a bottle of water", "a packet of chips", "a piece of cake", "two bottles of milk"],
      "commonMistakes": ["\"of\" vergessen: a bottle water (falsch) statt a bottle of water"]
    },
    {
      "id": "g5_28",
      "unit": 5,
      "code": "G28",
      "title": "some / any / no",
      "explanation": "some: in positiven Sätzen sowie bei Angeboten und Bitten. any: in Fragen und negativen Sätzen. no: kann statt \"not...any\" verwendet werden.",
      "examples": ["I've got some money.", "Have you got any money?", "I haven't got any money.", "I've got no money."],
      "commonMistakes": ["some in Fragen statt any verwenden", "any in positiven Aussagesätzen statt some verwenden"]
    },
    {
      "id": "g5_29",
      "unit": 5,
      "code": "G29",
      "title": "Zusammensetzungen mit some/any/every/no",
      "explanation": "some/any/every/no + body/one → Personen; + thing → Dinge; + where → Orte. Gleiche Regeln wie bei some/any: some in positiven Sätzen, any in Fragen/Verneinungen, every für Allgemeingültigkeit, no für Verneinung ohne \"not\".",
      "examples": ["somebody / anyone / everybody / nobody", "something / anything / everything / nothing", "somewhere / anywhere / everywhere / nowhere"],
      "commonMistakes": ["anybody in positiven Aussagesätzen statt somebody"]
    },
    {
      "id": "g5_30",
      "unit": 5,
      "code": "G30",
      "title": "much / many / a lot of",
      "explanation": "a lot of / lots of: mit zählbaren und unzählbaren Nomen in positiven Sätzen. much: nur mit unzählbaren Nomen, meist in Fragen und Verneinungen. many: nur mit zählbaren Nomen (Plural), meist in Fragen und Verneinungen. how much / how many für Mengenfragen.",
      "examples": ["I've got a lot of friends.", "I haven't got much time.", "How many apples have you got?", "How much water is there?"],
      "commonMistakes": ["much mit zählbaren Nomen (much apples statt many apples)", "many mit unzählbaren Nomen (many money statt much money)"]
    },
    {
      "id": "g5_31",
      "unit": 5,
      "code": "G31",
      "title": "a few / a couple of / a little",
      "explanation": "a few / a couple of: mit zählbaren Nomen im Plural, bedeutet \"ein paar\". a little: mit unzählbaren Nomen, bedeutet \"ein bisschen\".",
      "examples": ["a few apples", "a couple of friends", "a little water", "a little time"],
      "commonMistakes": ["a few mit unzählbaren Nomen statt a little"]
    }
  ],

  "grammarQuestions": [
    { "id": "q5_g26_001", "topicId": "g5_26", "type": "fillBlank", "prompt": "I'd like a bottle ___ water, please.", "answer": "of", "explanation": "Mengenangabe + of + Nomen." },
    { "id": "q5_g26_002", "topicId": "g5_26", "type": "multipleChoice", "prompt": "Wähle die richtige Mengenangabe: I bought a ___ of chips.", "options": ["packet", "bottle", "cup"], "answer": "packet", "explanation": "Chips kommen in a packet of chips." },
    { "id": "q5_g26_003", "topicId": "g5_26", "type": "fillBlank", "prompt": "Can I have a piece ___ cake?", "answer": "of", "explanation": "a piece of + Nomen." },

    { "id": "q5_g28_001", "topicId": "g5_28", "type": "multipleChoice", "prompt": "I've got ___ apples in my bag.", "options": ["some", "any", "no"], "answer": "some", "explanation": "Positiver Satz → some." },
    { "id": "q5_g28_002", "topicId": "g5_28", "type": "multipleChoice", "prompt": "Have you got ___ money?", "options": ["some", "any", "no"], "answer": "any", "explanation": "Frage → any." },
    { "id": "q5_g28_003", "topicId": "g5_28", "type": "multipleChoice", "prompt": "I haven't got ___ time today.", "options": ["some", "any", "no"], "answer": "any", "explanation": "Verneinung → any." },
    { "id": "q5_g28_004", "topicId": "g5_28", "type": "multipleChoice", "prompt": "Sorry, we've got ___ bananas left.", "options": ["some", "any", "no"], "answer": "no", "explanation": "no ersetzt \"not...any\" in positiver Satzform." },
    { "id": "q5_g28_005", "topicId": "g5_28", "type": "fillBlank", "prompt": "Would you like ___ tea? (Angebot)", "answer": "some", "explanation": "Bei Angeboten benutzt man some, auch in Frageform." },

    { "id": "q5_g29_001", "topicId": "g5_29", "type": "multipleChoice", "prompt": "There isn't ___ in the fridge.", "options": ["something", "anything", "everything"], "answer": "anything", "explanation": "Verneinung → anything." },
    { "id": "q5_g29_002", "topicId": "g5_29", "type": "multipleChoice", "prompt": "I can see ___ standing at the door.", "options": ["nobody", "somebody", "everybody"], "answer": "somebody", "explanation": "Positiver Aussagesatz → somebody." },
    { "id": "q5_g29_003", "topicId": "g5_29", "type": "multipleChoice", "prompt": "There's ___ to do here — I'm bored!", "options": ["everything", "nothing", "something"], "answer": "nothing", "explanation": "\"nichts zu tun\" → nothing." },
    { "id": "q5_g29_004", "topicId": "g5_29", "type": "fillBlank", "prompt": "You can sit ___ you like. (überall)", "answer": "anywhere", "explanation": "\"überall, wo du willst\" → anywhere." },

    { "id": "q5_g30_001", "topicId": "g5_30", "type": "multipleChoice", "prompt": "How ___ apples have you got?", "options": ["much", "many", "a little"], "answer": "many", "explanation": "apples ist zählbar → many." },
    { "id": "q5_g30_002", "topicId": "g5_30", "type": "multipleChoice", "prompt": "How ___ water is there in the bottle?", "options": ["much", "many", "a few"], "answer": "much", "explanation": "water ist unzählbar → much." },
    { "id": "q5_g30_003", "topicId": "g5_30", "type": "multipleChoice", "prompt": "I've got ___ friends at school.", "options": ["a lot of", "much", "any"], "answer": "a lot of", "explanation": "a lot of funktioniert mit zählbaren Nomen im positiven Satz." },
    { "id": "q5_g30_004", "topicId": "g5_30", "type": "fillBlank", "prompt": "I haven't got ___ money left. (much/many)", "answer": "much", "explanation": "money ist unzählbar → much." },

    { "id": "q5_g31_001", "topicId": "g5_31", "type": "multipleChoice", "prompt": "There are only ___ eggs left.", "options": ["a few", "a little", "much"], "answer": "a few", "explanation": "eggs ist zählbar (Plural) → a few." },
    { "id": "q5_g31_002", "topicId": "g5_31", "type": "multipleChoice", "prompt": "Can I have ___ sugar in my tea?", "options": ["a little", "a few", "many"], "answer": "a little", "explanation": "sugar ist unzählbar → a little." },
    { "id": "q5_g31_003", "topicId": "g5_31", "type": "fillBlank", "prompt": "We invited a ___ of friends. (couple)", "answer": "couple", "explanation": "a couple of + Plural-Nomen = ein paar." }
  ],

  "conversationScenarios": [
    {
      "id": "c5_cafe",
      "unit": 5,
      "title": "Im Café / Etwas bestellen",
      "level": 2,
      "goal": "Höfliche Formulierungen, Zahlen (Preise), Lebensmittelvokabular",
      "startNode": "n1",
      "nodes": {
        "n1": {
          "npcLine": "Good afternoon! Welcome to The Green Café. Are you ready to order?",
          "choices": [
            { "text": "Yes, please. Can I have a lemonade and a piece of cake?", "quality": "good", "feedback": "Sehr gut — höflich mit \"Can I have...\" und der Mengenangabe \"a piece of\".", "next": "n2" },
            { "text": "Give me lemonade.", "quality": "wrong", "feedback": "Klingt unhöflich. Besser: \"Can I have a lemonade, please?\"", "next": "n2" },
            { "text": "I'd like a lemonade, please.", "quality": "ok", "feedback": "Gut und höflich — auch \"I'd like...\" funktioniert super.", "next": "n2" }
          ]
        },
        "n2": {
          "npcLine": "Great choice! That's £4.50 in total. Anything else?",
          "choices": [
            { "text": "No, thank you. That's all.", "quality": "good", "feedback": "Perfekt, klare und höfliche Antwort.", "next": "n3" },
            { "text": "How much is that again?", "quality": "ok", "feedback": "Völlig okay, wenn du den Preis nicht verstanden hast.", "next": "n3" }
          ]
        },
        "n3": {
          "npcLine": "Here you go — one lemonade and a piece of cake. Enjoy!",
          "choices": [
            { "text": "Thank you very much!", "quality": "good", "feedback": "Schön abgeschlossen!", "next": "n4" }
          ]
        },
        "n4": {
          "npcLine": "You're welcome — have a lovely afternoon!",
          "choices": []
        }
      },
      "endNodes": ["n4"]
    },
    {
      "id": "c5_telephone",
      "unit": 5,
      "title": "Am Telefon",
      "level": 2,
      "goal": "Telefondialoge, Höflichkeitsformeln, Present Progressive",
      "startNode": "n1",
      "nodes": {
        "n1": {
          "npcLine": "[Ring, ring!] Hello? This is the King residence. Who's calling, please?",
          "choices": [
            { "text": "Hello, this is Juna speaking. Can I speak to Emma, please?", "quality": "good", "feedback": "Genau die richtige Telefonformel!", "next": "n2" },
            { "text": "It's me. Where is Emma?", "quality": "wrong", "feedback": "Am Telefon sagt man lieber \"This is ... speaking\" statt \"It's me\" — der andere kennt deine Stimme ja nicht.", "next": "n2" }
          ]
        },
        "n2": {
          "npcLine": "I'm afraid Emma isn't here right now. Can I take a message?",
          "choices": [
            { "text": "Yes, please. Can you tell her I called?", "quality": "good", "feedback": "Sehr gut formuliert.", "next": "n3" },
            { "text": "No. Bye.", "quality": "wrong", "feedback": "Etwas unhöflich — besser kurz erklären oder freundlich verabschieden, z.B. mit \"That's okay, I'll call back later.\"", "next": "n3" }
          ]
        },
        "n3": {
          "npcLine": "Sure, I'll tell her. Can you call back later, or should she call you back?",
          "choices": [
            { "text": "She can call me back later, thank you.", "quality": "good", "feedback": "Klar und höflich.", "next": "n4" },
            { "text": "I'll get back to you.", "quality": "ok", "feedback": "Grammatisch korrekt, aber hier eher unpassend — diese Phrase benutzt normalerweise die Person, die zurückruft.", "next": "n4" }
          ]
        },
        "n4": {
          "npcLine": "No problem. Goodbye!",
          "choices": [
            { "text": "Goodbye, thank you!", "quality": "good", "feedback": "Schöner Abschluss des Telefonats.", "next": "n5" }
          ]
        },
        "n5": { "npcLine": "[Click.]", "choices": [] }
      },
      "endNodes": ["n5"]
    },
    {
      "id": "c5_market",
      "unit": 5,
      "title": "Im Laden / Auf dem Markt",
      "level": 2,
      "goal": "Einkaufsvokabular, Mengenangaben, Höflichkeit, Zahlen & Preise",
      "startNode": "n1",
      "nodes": {
        "n1": {
          "npcLine": "Good morning! Welcome to the market. What can I do for you today?",
          "choices": [
            { "text": "I'm looking for a present for my mum.", "quality": "good", "feedback": "Sehr natürlich — genau die Formel aus dem Buch.", "next": "n2" },
            { "text": "Give me a present.", "quality": "wrong", "feedback": "Zu direkt. Besser: \"I'm looking for...\" oder \"Can I have...\"", "next": "n2" }
          ]
        },
        "n2": {
          "npcLine": "How about this bracelet? It's a special offer today.",
          "choices": [
            { "text": "How much is it?", "quality": "good", "feedback": "Genau richtig, um nach dem Preis zu fragen.", "next": "n3" },
            { "text": "Is it expensive?", "quality": "ok", "feedback": "Funktioniert auch, aber \"How much is it?\" ist die direktere Standardfrage.", "next": "n3" }
          ]
        },
