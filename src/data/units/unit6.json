  "grammarTopics": [
    {
      "id": "g6_32",
      "unit": 6,
      "code": "G32-33",
      "title": "Modalverben: can / can't / must / mustn't / needn't",
      "explanation": "can = dürfen/können (Erlaubnis, Fähigkeit). can't = nicht dürfen/können. must = müssen (erforderlich). mustn't = verboten! needn't = nicht nötig, aber erlaubt. Wichtigster Stolperstein: mustn't (verboten) ist NICHT dasselbe wie needn't (nicht nötig). Modalverben haben für alle Personen dieselbe Form (kein -s bei he/she/it).",
      "examples": [
        "You can invite five people.",
        "You can't watch TV all night.",
        "You must get a DVD.",
        "You mustn't eat too many sweets.",
        "You needn't buy a cake."
      ],
      "commonMistakes": [
        "mustn't und needn't verwechseln",
        "he/she/it + s beim Modalverb (he cans statt he can)"
      ]
    },
    {
      "id": "g6_34",
      "unit": 6,
      "code": "G34",
      "title": "Simple Past",
      "explanation": "Für Ereignisse in der Vergangenheit. Regelmäßige Verben: Infinitiv + -ed (play → played, want → wanted, invite → invited, trip → tripped — Verdopplung des Endkonsonanten bei kurzem betontem Vokal). Unregelmäßige Verben haben eigene Formen, die man auswendig lernen muss (go → went, have → had, be → was/were, buy → bought). Signalwörter: last week/month/year, two days ago, yesterday.",
      "examples": [
        "I played football yesterday.",
        "She went to the party last week.",
        "We had a great time.",
        "They didn't come (Verneinung: didn't + Infinitiv)."
      ],
      "commonMistakes": [
        "-ed an unregelmäßige Verben anhängen (goed statt went)",
        "ago vor die Zeitangabe stellen statt danach"
      ]
    },
    {
      "id": "g6_dates",
      "unit": 6,
      "code": "Check-in",
      "title": "Das Datum sagen",
      "explanation": "Für das Datum benutzt man Ordnungszahlen (1st, 2nd, 3rd, 4th...) zusammen mit dem Monat. \"When is your birthday? – It's on 1st June. / My birthday is in April.\" Vor dem Tag steht \"on\", vor dem reinen Monat \"in\". Im amerikanischen Englisch steht zuerst der Monat, dann der Tag (April 1st = 1. April).",
      "examples": [
        "It's on 1st June.",
        "My birthday is in April.",
        "The party is on 3rd October.",
        "AE: July 4th = 4. Juli"
      ],
      "commonMistakes": [
        "Kardinalzahl statt Ordnungszahl (on 1 June statt on 1st June)",
        "on/in verwechseln"
      ]
    }
  ],
  "grammarQuestions": [
    {
      "id": "q6_g32_001",
      "topicId": "g6_32",
      "type": "multipleChoice",
      "prompt": "You ___ invite five people to your party.",
      "options": [
        "can",
        "must",
        "mustn't"
      ],
      "answer": "can",
      "explanation": "Erlaubnis → can.",
      "optionHints": {
        "must": "Fast richtig! \"must\" bedeutet \"müssen\" — hier geht es aber um Erlaubnis: \"can\".",
        "mustn't": "\"mustn't\" bedeutet \"verboten\" — hier ist es aber erlaubt: \"can\"."
      }
    },
    {
      "id": "q6_g32_002",
      "topicId": "g6_32",
      "type": "multipleChoice",
      "prompt": "You ___ eat too many sweets — it's bad for you!",
      "options": [
        "mustn't",
        "needn't",
        "can"
      ],
      "answer": "mustn't",
      "explanation": "Verbot → mustn't.",
      "optionHints": {
        "needn't": "Fast richtig! \"needn't\" bedeutet \"nicht nötig, aber erlaubt\" — hier ist es aber verboten: \"mustn't\".",
        "can": "\"can\" würde bedeuten, dass es erlaubt ist — hier ist das Gegenteil gemeint: \"mustn't\"."
      }
    },
    {
      "id": "q6_g32_003",
      "topicId": "g6_32",
      "type": "multipleChoice",
      "prompt": "You ___ buy a cake — I've already got one.",
      "options": [
        "needn't",
        "mustn't",
        "must"
      ],
      "answer": "needn't",
      "explanation": "Nicht nötig, aber erlaubt → needn't.",
      "optionHints": {
        "mustn't": "Fast richtig! \"mustn't\" bedeutet \"verboten\" — hier ist es aber einfach nicht nötig: \"needn't\".",
        "must": "\"must\" bedeutet \"müssen\" — hier ist es aber freiwillig: \"needn't\"."
      }
    },
    {
      "id": "q6_g32_004",
      "topicId": "g6_32",
      "type": "multipleChoice",
      "prompt": "You ___ get a DVD for the party — it's important!",
      "options": [
        "must",
        "can't",
        "needn't"
      ],
      "answer": "must",
      "explanation": "Erforderlich → must.",
      "optionHints": {
        "can't": "\"can't\" würde \"nicht können/dürfen\" bedeuten — hier ist es aber wichtig und nötig: \"must\".",
        "needn't": "Fast richtig! \"needn't\" bedeutet \"nicht nötig\" — hier steht aber, dass es wichtig ist: \"must\"."
      }
    },
    {
      "id": "q6_g32_005",
      "topicId": "g6_32",
      "type": "multipleChoice",
      "prompt": "He ___ swim very well.",
      "options": [
        "can",
        "cans",
        "canning"
      ],
      "answer": "can",
      "explanation": "Modalverben bekommen kein -s bei he/she/it.",
      "optionHints": {
        "cans": "Modalverben wie \"can\" bekommen bei he/she/it kein -s! Merke: \"he can\", nicht \"he cans\".",
        "canning": "Modalverben stehen immer in der Grundform — kein -ing! Es heißt einfach \"can\"."
      }
    },
    {
      "id": "q6_g32_006",
      "topicId": "g6_32",
      "type": "fillBlank",
      "prompt": "You ___ watch TV all night. (nicht erlaubt)",
      "answer": "can't",
      "explanation": "\"can't\" zeigt hier ein Verbot: es ist nicht erlaubt, die ganze Nacht fernzusehen."
    },
    {
      "id": "q6_g34_001",
      "topicId": "g6_34",
      "type": "fillBlank",
      "prompt": "Yesterday I ___ (play) football with my friends.",
      "answer": "played",
      "explanation": "\"play\" ist regelmäßig — einfach \"-ed\" anhängen: played."
    },
    {
      "id": "q6_g34_002",
      "topicId": "g6_34",
      "type": "fillBlank",
      "prompt": "She ___ (go) to the party last week.",
      "answer": "went",
      "explanation": "\"go\" ist unregelmäßig — die Form musst du auswendig lernen: go → went (nicht \"goed\")."
    },
    {
      "id": "q6_g34_003",
      "topicId": "g6_34",
      "type": "fillBlank",
      "prompt": "We ___ (have) a great time at the party.",
      "answer": "had",
      "explanation": "\"have\" ist unregelmäßig: have → had (nicht \"haved\")."
    },
    {
      "id": "q6_g34_004",
      "topicId": "g6_34",
      "type": "fillBlank",
      "prompt": "He ___ (trip) over the chair and hurt his leg.",
      "answer": "tripped",
      "explanation": "Bei kurzem, betontem Vokal wird der Endkonsonant verdoppelt: trip → tripped (nicht \"triped\")."
    },
    {
      "id": "q6_g34_005",
      "topicId": "g6_34",
      "type": "multipleChoice",
      "prompt": "Two days ___ we celebrated her birthday.",
      "options": [
        "ago",
        "before",
        "last"
      ],
      "answer": "ago",
      "explanation": "ago steht nach der Zeitangabe: two days ago.",
      "optionHints": {
        "before": "Fast richtig! \"before\" steht meist vor einer Zeitangabe — \"ago\" kommt danach: \"two days ago\".",
        "last": "\"last\" benutzt man z. B. bei \"last week\" — hier passt aber \"ago\" nach der Zeitangabe."
      }
    },
    {
      "id": "q6_g34_006",
      "topicId": "g6_34",
      "type": "multipleChoice",
      "prompt": "Which is the correct Simple Past of \"buy\"?",
      "options": [
        "bought",
        "buyed",
        "buys"
      ],
      "answer": "bought",
      "explanation": "buy ist unregelmäßig: buy → bought.",
      "optionHints": {
        "buyed": "\"buy\" ist unregelmäßig — es gibt kein \"-ed\" bei diesem Verb! Die richtige Form ist \"bought\".",
        "buys": "Das ist die Präsensform (er/sie/es) — für die Vergangenheit brauchst du \"bought\"."
      }
    },
    {
      "id": "q6_g34_007",
      "topicId": "g6_34",
      "type": "fillBlank",
