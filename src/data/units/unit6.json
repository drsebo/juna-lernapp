  "grammarTopics": [
    {
      "id": "g6_32",
      "unit": 6,
      "code": "G32-33",
      "title": "Modalverben: can / can't / must / mustn't / needn't",
      "explanation": "can = dürfen/können (Erlaubnis, Fähigkeit). can't = nicht dürfen/können. must = müssen (erforderlich). mustn't = verboten! needn't = nicht nötig, aber erlaubt. Wichtigster Stolperstein: mustn't (verboten) ist NICHT dasselbe wie needn't (nicht nötig). Modalverben haben für alle Personen dieselbe Form (kein -s bei he/she/it).",
      "examples": ["You can invite five people.", "You can't watch TV all night.", "You must get a DVD.", "You mustn't eat too many sweets.", "You needn't buy a cake."],
      "commonMistakes": ["mustn't und needn't verwechseln", "he/she/it + s beim Modalverb (he cans statt he can)"]
    },
    {
      "id": "g6_34",
      "unit": 6,
      "code": "G34",
      "title": "Simple Past",
      "explanation": "Für Ereignisse in der Vergangenheit. Regelmäßige Verben: Infinitiv + -ed (play → played, want → wanted, invite → invited, trip → tripped — Verdopplung des Endkonsonanten bei kurzem betontem Vokal). Unregelmäßige Verben haben eigene Formen, die man auswendig lernen muss (go → went, have → had, be → was/were, buy → bought). Signalwörter: last week/month/year, two days ago, yesterday.",
      "examples": ["I played football yesterday.", "She went to the party last week.", "We had a great time.", "They didn't come (Verneinung: didn't + Infinitiv)."],
      "commonMistakes": ["-ed an unregelmäßige Verben anhängen (goed statt went)", "ago vor die Zeitangabe stellen statt danach"]
    },
    {
      "id": "g6_dates",
      "unit": 6,
      "code": "Check-in",
      "title": "Das Datum sagen",
      "explanation": "Für das Datum benutzt man Ordnungszahlen (1st, 2nd, 3rd, 4th...) zusammen mit dem Monat. \"When is your birthday? – It's on 1st June. / My birthday is in April.\" Vor dem Tag steht \"on\", vor dem reinen Monat \"in\". Im amerikanischen Englisch steht zuerst der Monat, dann der Tag (April 1st = 1. April).",
      "examples": ["It's on 1st June.", "My birthday is in April.", "The party is on 3rd October.", "AE: July 4th = 4. Juli"],
      "commonMistakes": ["Kardinalzahl statt Ordnungszahl (on 1 June statt on 1st June)", "on/in verwechseln"]
    }
  ],

  "grammarQuestions": [
    { "id": "q6_g32_001", "topicId": "g6_32", "type": "multipleChoice", "prompt": "You ___ invite five people to your party.", "options": ["can", "must", "mustn't"], "answer": "can", "explanation": "Erlaubnis → can." },
    { "id": "q6_g32_002", "topicId": "g6_32", "type": "multipleChoice", "prompt": "You ___ eat too many sweets — it's bad for you!", "options": ["mustn't", "needn't", "can"], "answer": "mustn't", "explanation": "Verbot → mustn't." },
    { "id": "q6_g32_003", "topicId": "g6_32", "type": "multipleChoice", "prompt": "You ___ buy a cake — I've already got one.", "options": ["needn't", "mustn't", "must"], "answer": "needn't", "explanation": "Nicht nötig, aber erlaubt → needn't." },
    { "id": "q6_g32_004", "topicId": "g6_32", "type": "multipleChoice", "prompt": "You ___ get a DVD for the party — it's important!", "options": ["must", "can't", "needn't"], "answer": "must", "explanation": "Erforderlich → must." },
    { "id": "q6_g32_005", "topicId": "g6_32", "type": "multipleChoice", "prompt": "He ___ swim very well.", "options": ["can", "cans", "canning"], "answer": "can", "explanation": "Modalverben bekommen kein -s bei he/she/it." },
    { "id": "q6_g32_006", "topicId": "g6_32", "type": "fillBlank", "prompt": "You ___ watch TV all night. (nicht erlaubt)", "answer": "can't", "explanation": "Verbot/Unfähigkeit → can't." },

    { "id": "q6_g34_001", "topicId": "g6_34", "type": "fillBlank", "prompt": "Yesterday I ___ (play) football with my friends.", "answer": "played", "explanation": "Regelmäßiges Verb: play + ed." },
    { "id": "q6_g34_002", "topicId": "g6_34", "type": "fillBlank", "prompt": "She ___ (go) to the party last week.", "answer": "went", "explanation": "go ist unregelmäßig: go → went." },
    { "id": "q6_g34_003", "topicId": "g6_34", "type": "fillBlank", "prompt": "We ___ (have) a great time at the party.", "answer": "had", "explanation": "have ist unregelmäßig: have → had." },
    { "id": "q6_g34_004", "topicId": "g6_34", "type": "fillBlank", "prompt": "He ___ (trip) over the chair and hurt his leg.", "answer": "tripped", "explanation": "Kurzer betonter Vokal → Endkonsonant verdoppeln: trip → tripped." },
    { "id": "q6_g34_005", "topicId": "g6_34", "type": "multipleChoice", "prompt": "Two days ___ we celebrated her birthday.", "options": ["ago", "before", "last"], "answer": "ago", "explanation": "ago steht nach der Zeitangabe: two days ago." },
    { "id": "q6_g34_006", "topicId": "g6_34", "type": "multipleChoice", "prompt": "Which is the correct Simple Past of \"buy\"?", "options": ["bought", "buyed", "buys"], "answer": "bought", "explanation": "buy ist unregelmäßig: buy → bought." },
    { "id": "q6_g34_007", "topicId": "g6_34", "type": "fillBlank", "prompt": "They ___ (not/come) to the party. (Verneinung)", "answer": "didn't come", "explanation": "Verneinung im Simple Past: didn't + Infinitiv." },

    { "id": "q6_dates_001", "topicId": "g6_dates", "type": "multipleChoice", "prompt": "When is your birthday? – It's ___ 1st June.", "options": ["on", "in", "at"], "answer": "on", "explanation": "Vor einem konkreten Tag steht on." },
    { "id": "q6_dates_002", "topicId": "g6_dates", "type": "multipleChoice", "prompt": "My birthday is ___ April.", "options": ["in", "on", "at"], "answer": "in", "explanation": "Vor einem Monat (ohne Tag) steht in." },
    { "id": "q6_dates_003", "topicId": "g6_dates", "type": "fillBlank", "prompt": "Ordnungszahl für 3: thi__", "answer": "third", "explanation": "3 → third." },
    { "id": "q6_dates_004", "topicId": "g6_dates", "type": "fillBlank", "prompt": "Ordnungszahl für 5:", "answer": "fifth", "explanation": "5 → fifth (unregelmäßig gebildet)." },
    { "id": "q6_dates_005", "topicId": "g6_dates", "type": "multipleChoice", "prompt": "Wie heißt der 12. auf Englisch?", "options": ["twelfth", "twelveth", "twelth"], "answer": "twelfth", "explanation": "12 → twelfth." }
  ],

  "conversationScenarios": [
    {
      "id": "c6_party_planning",
      "unit": 6,
      "title": "Eine Geburtstagsparty planen",
      "level": 2,
      "goal": "Party-Vokabeln, can/can't (Erlaubnis), Present Progressive, Zukunftspläne",
      "startNode": "n1",
      "nodes": {
        "n1": {
          "npcLine": "Yay, it's your birthday soon! Are you having a party? What are we going to do?",
          "choices": [
            { "text": "Yes, I'm having a party on Saturday.", "quality": "good", "feedback": "Sehr gut — Present Progressive für Zukunftspläne, genau wie im Buch.", "next": "n2" },
            { "text": "Yes, I have a party Saturday.", "quality": "ok", "feedback": "Man versteht es, aber für feste Zukunftspläne ist \"I'm having a party on Saturday\" natürlicher.", "next": "n2" }
          ]
        },
        "n2": {
          "npcLine": "Awesome! What's the theme? And who can come?",
          "choices": [
            { "text": "It's a pool party! You can bring your little brother too.", "quality": "good", "feedback": "Schön natürlich formuliert mit can für Erlaubnis.", "next": "n3" },
            { "text": "No theme. Everyone comes.", "quality": "ok", "feedback": "Grammatisch okay, aber sehr knapp — versuch ganze Sätze wie \"Everyone can come.\"", "next": "n3" }
          ]
        },
        "n3": {
          "npcLine": "Sounds great! Can I bring my little brother too?",
          "choices": [
            { "text": "Sure, you can bring him. There are balloons and a big cake!", "quality": "good", "feedback": "Perfekt — can für Erlaubnis plus schöne Partyvokabeln.", "next": "n4" },
            { "text": "You mustn't bring your brother.", "quality": "wrong", "feedback": "mustn't klingt hier nach einem strengen Verbot — falls das nicht gemeint ist, ist \"you can't\" oder besser einfach \"sorry, not this time\" passender.", "next": "n4" }
          ]
        },
        "n4": {
          "npcLine": "Great, we can dance and play games together!",
          "choices": [
            { "text": "Yes! Let's celebrate together!", "quality": "good", "feedback": "Schöner Abschluss, genau die Buchphrase.", "next": "n5" }
          ]
        },
        "n5": { "npcLine": "Can't wait! See you on Saturday!", "choices": [] }
      },
      "endNodes": ["n5"]
    },
    {
      "id": "c6_party_rules",
      "unit": 6,
      "title": "Party-Regeln",
      "level": 2,
      "goal": "Modalverben can / can't / mustn't (Erlaubnis, Fähigkeit, Verbot)",
      "startNode": "n1",
      "nodes": {
        "n1": {
          "npcLine": "Welcome to the party! Before we start, here are the rules. You can play everywhere, but there are a few things you mustn't do. Ready?",
          "choices": [
            { "text": "Okay, what can't we do?", "quality": "good", "feedback": "Gute, natürliche Rückfrage.", "next": "n2" },
            { "text": "Okay, what we can't do?", "quality": "ok", "feedback": "Fast richtig — in Fragen braucht man die Umstellung: \"What can't we do?\"", "next": "n2" }
          ]
        },
        "n2": {
          "npcLine": "You mustn't run near the pool — it's dangerous! But you can dance and eat as much cake as you like.",
          "choices": [
            { "text": "Got it. Do we have to tidy up afterwards?", "quality": "good", "feedback": "Super Frage, ganz aus dem Buch!", "next": "n3" },
            { "text": "Got it. We must tidy up afterwards?", "quality": "wrong", "feedback": "Als Frage braucht \"must\" die Umstellung mit \"do\": \"Do we have to tidy up afterwards?\" ist die natürlichere Formulierung.", "next": "n3" }
          ]
        },
        "n3": {
          "npcLine": "No, you needn't — we've got a cleaning team! Can I open my presents now?",
          "choices": [
            { "text": "Not yet — you can open them after the cake!", "quality": "good", "feedback": "Toll formuliert, can für Erlaubnis richtig eingesetzt.", "next": "n4" }
          ]
        },
        "n4": { "npcLine": "Okay! Let's dance until then!", "choices": [] }
      },
      "endNodes": ["n4"]
    }
  ]
